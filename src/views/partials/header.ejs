<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'HR System' %></title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
</head>
<body class="bg-light">
  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/dashboard">HR System</a>
      <div class="navbar-nav me-auto">
        <a class="nav-link" href="/dashboard" data-testid="nav-dashboard">Dashboard</a>
        <a class="nav-link" href="/employees" data-testid="nav-employees">Employees</a>
        <a class="nav-link" href="/departments" data-testid="nav-departments">Departments</a>
      </div>
      <span class="navbar-text text-light me-3"><%= currentUser.fullName %></span>
      <a class="btn btn-outline-light btn-sm" href="/logout" data-testid="logout">Logout</a>
    </div>
  </nav>
  <% } %>
  <main class="container py-4">
