<%- include('../partials/header', { title: 'Employees' }) %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="mb-0">Employees</h2>
  <a class="btn btn-primary" href="/employees/new" data-testid="new-employee">+ New Employee</a>
</div>
<form class="card bg-white shadow-sm mb-3" method="get" action="/employees"
      data-testid="employee-search">
  <div class="card-body row g-3 align-items-end">
    <div class="col-md-3">
      <label class="form-label" for="search-name">Name</label>
      <input class="form-control" type="text" id="search-name" name="name"
             value="<%= filters.name %>" data-testid="search-name">
    </div>
    <div class="col-md-3">
      <label class="form-label" for="search-department">Department</label>
      <input class="form-control" type="text" id="search-department" name="department"
             value="<%= filters.department %>" data-testid="search-department">
    </div>
    <div class="col-md-3">
      <label class="form-label" for="search-job-title">Job Title</label>
      <input class="form-control" type="text" id="search-job-title" name="job_title"
             value="<%= filters.job_title %>" data-testid="search-job-title">
    </div>
    <div class="col-md-3">
      <label class="form-label d-block">Status</label>
      <div class="btn-group" role="group" aria-label="Status filter">
        <input class="btn-check" type="radio" name="status" id="status-active" value="active"
               <%= filters.status === 'active' ? 'checked' : '' %> data-testid="status-active">
        <label class="btn btn-outline-secondary" for="status-active">Active</label>
        <input class="btn-check" type="radio" name="status" id="status-inactive" value="inactive"
               <%= filters.status === 'inactive' ? 'checked' : '' %> data-testid="status-inactive">
        <label class="btn btn-outline-secondary" for="status-inactive">Inactive</label>
        <input class="btn-check" type="radio" name="status" id="status-all" value="all"
               <%= filters.status === 'all' ? 'checked' : '' %> data-testid="status-all">
        <label class="btn btn-outline-secondary" for="status-all">All</label>
      </div>
    </div>
    <div class="col-12">
      <button class="btn btn-primary" type="submit" data-testid="search-submit">Search</button>
      <a class="btn btn-outline-secondary" href="/employees" data-testid="search-reset">Reset</a>
    </div>
  </div>
</form>
<table class="table table-striped bg-white shadow-sm" data-testid="employees-table">
  <thead>
    <tr>
      <th>Name</th><th>Email</th><th>Department</th><th>Job Title</th>
      <th>Status</th><th class="text-end">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (employees.length === 0) { %>
    <tr><td colspan="6" class="text-center text-muted">No employees yet.</td></tr>
    <% } %>
    <% employees.forEach(function(e) { %>
    <tr data-testid="employee-row">
      <td><%= e.first_name %> <%= e.last_name %></td>
      <td><%= e.email %></td>
      <td><%= e.department_name || '—' %></td>
      <td><%= e.job_title || '—' %></td>
      <td>
        <span class="badge <%= e.status === 'active' ? 'text-bg-success' : 'text-bg-secondary' %>">
          <%= e.status %>
        </span>
      </td>
      <td class="text-end">
        <a class="btn btn-sm btn-outline-secondary" href="/employees/<%= e.id %>/edit"
           data-testid="edit-employee">Edit</a>
        <form class="d-inline" method="post" action="/employees/<%= e.id %>/delete"
              onsubmit="return confirm('Delete this employee?');">
          <button class="btn btn-sm btn-outline-danger" type="submit"
                  data-testid="delete-employee">Delete</button>
        </form>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
<%- include('../partials/footer') %>
