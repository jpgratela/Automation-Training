<%- include('../partials/header', { title: 'Employees' }) %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="mb-0">Employees</h2>
  <a class="btn btn-primary" href="/employees/new" data-testid="new-employee">+ New Employee</a>
</div>
<table class="table table-striped bg-white shadow-sm" data-testid="employees-table">
  <thead>
    <tr>
      <th>Name</th><th>Email</th><th>Department</th><th>Job Title</th>
      <th>Status</th><th class="text-end">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (employees.length === 0) { %>
    <tr><td colspan="6" class="text-center text-muted">No employees yet.</td></tr>
    <% } %>
    <% employees.forEach(function(e) { %>
    <tr data-testid="employee-row">
      <td><%= e.first_name %> <%= e.last_name %></td>
      <td><%= e.email %></td>
      <td><%= e.department_name || '—' %></td>
      <td><%= e.job_title || '—' %></td>
      <td>
        <span class="badge <%= e.status === 'active' ? 'text-bg-success' : 'text-bg-secondary' %>">
          <%= e.status %>
        </span>
      </td>
      <td class="text-end">
        <a class="btn btn-sm btn-outline-secondary" href="/employees/<%= e.id %>/edit"
           data-testid="edit-employee">Edit</a>
        <form class="d-inline" method="post" action="/employees/<%= e.id %>/delete"
              onsubmit="return confirm('Delete this employee?');">
          <button class="btn btn-sm btn-outline-danger" type="submit"
                  data-testid="delete-employee">Delete</button>
        </form>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
<%- include('../partials/footer') %>
